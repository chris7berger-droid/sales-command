#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: abort if this branch is behind origin/main on migrations.
# Prevents ledger divergence when `supabase db push` runs from a stale branch
# (2026-05-18 incident: repair --status reverted on live migrations).

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "main" ]; then
  exit 0
fi

# Only check when the push includes migration changes
MIGRATION_CHANGES=$(git diff --name-only HEAD@{push}..HEAD -- supabase/migrations/ 2>/dev/null || echo "")
STAGED_MIGRATIONS=$(git diff --name-only origin/"$CURRENT_BRANCH"..HEAD -- supabase/migrations/ 2>/dev/null || echo "check")

if [ -z "$MIGRATION_CHANGES" ] && [ -z "$STAGED_MIGRATIONS" ]; then
  exit 0
fi

git fetch origin main --quiet 2>/dev/null || true

MISSING=$(git log origin/main ^HEAD --oneline -- supabase/migrations/)

if [ -n "$MISSING" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  PUSH BLOCKED — branch is behind main on migrations        ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "These migration commits exist on origin/main but NOT on this branch:"
  echo ""
  echo "$MISSING"
  echo ""
  echo "Missing migration files:"
  git diff --name-only HEAD origin/main -- supabase/migrations/ | while read -r f; do
    echo "  $f"
  done
  echo ""
  echo "FIX: merge main into your branch before pushing:"
  echo ""
  echo "  git merge origin/main"
  echo ""
  echo "Pushing without merging risks ledger divergence — a stale branch"
  echo "causes \`supabase db push\` to see remote-only entries and tempts"
  echo "\`repair --status reverted\` on live migrations (2026-05-18 incident)."
  echo ""
  exit 1
fi

exit 0
